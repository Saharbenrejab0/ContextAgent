# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here

# ── LangSmith (optional — for tracing) ────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=contextagent

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db

# ── Chunking ──────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ── Retrieval ─────────────────────────────────────────────────
TOP_K_RESULTS=5

# ── Memory ────────────────────────────────────────────────────
MEMORY_WINDOW=6